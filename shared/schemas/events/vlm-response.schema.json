{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentihome.io/schemas/v1/events/vlm-response.schema.json",
  "title": "VLMResponse",
  "description": "Structured decision JSON returned by the VLM. See §09.",
  "type": "object",
  "required": ["request_id", "criticality", "confidence", "backend"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "event_id": { "type": "string" },
    "trace_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "criticality": {
      "type": "string",
      "enum": ["info", "warning", "alert"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rules_fired": {
      "type": "array",
      "items": { "type": "string" }
    },
    "explanation": {
      "type": "string",
      "description": "Human-readable reasoning shown in the alert."
    },
    "identified_actors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "actor_id": { "type": "string" },
          "name": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "limiting_factors": {
      "type": "array",
      "description": "Confidence-limiting factors that may trigger remediation + deeper assessment.",
      "items": {
        "type": "string",
        "enum": [
          "low_light",
          "subject_too_small",
          "subject_partially_occluded",
          "low_resolution",
          "adverse_weather",
          "multiple_subjects",
          "ambiguous_rule",
          "needs_human_judgment",
          "camera_obstructed"
        ]
      }
    },
    "deeper_assessment": { "type": "boolean" },
    "journey_open": { "type": "boolean" },
    "attention_mode": {
      "type": "string",
      "enum": ["none", "pool_safety", "intruder_watch", "medical"]
    },
    "backend": {
      "type": "string",
      "description": "Which VLM backend produced the response."
    },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "tokens_used": { "type": "integer", "minimum": 0 }
  }
}
