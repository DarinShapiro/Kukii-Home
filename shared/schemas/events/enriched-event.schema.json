{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentihome.io/schemas/v1/events/enriched-event.schema.json",
  "title": "EnrichedEvent",
  "description": "TriggerEvent + detector enrichment + context references. Produced by the preprocessor or built-in adapter; consumed by the triage worker before VLM call.",
  "type": "object",
  "required": ["event_id", "camera_id", "timestamp", "frames", "privacy_tier"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "camera_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "frames": {
      "type": "array",
      "minItems": 1,
      "description": "Frame URIs (in object store) selected for VLM input.",
      "items": { "type": "string" }
    },
    "detections": {
      "type": "array",
      "description": "Per-frame structured detection output from the fast detector.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "class": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
          "track_id": { "type": "string" }
        }
      }
    },
    "embeddings": {
      "type": "object",
      "description": "Face/body re-ID embeddings keyed by track_id.",
      "additionalProperties": true
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "low_light",
          "subject_too_small",
          "subject_partially_occluded",
          "low_resolution",
          "adverse_weather",
          "multiple_subjects",
          "camera_obstructed"
        ]
      }
    },
    "preprocessing_mode": {
      "type": "string",
      "enum": ["native", "built-in", "service", "direct"]
    },
    "preprocessing_latency_ms": { "type": "integer", "minimum": 0 },
    "privacy_tier": {
      "type": "string",
      "enum": ["local_only", "cloud_eligible", "cloud_any"]
    },
    "retention_days": { "type": "integer", "minimum": 0 }
  }
}
