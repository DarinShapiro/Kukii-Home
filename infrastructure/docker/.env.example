# Copy to .env and fill in your values.
# .env is gitignored.

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=long_lived_access_token_here

# Cloud VLM (optional — used as fallback when local GPU saturated)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Override which NVR adapter(s) start
# Comma-separated list. Defaults: rtsp-direct
# NVR_ADAPTERS=agent-dvr,frigate
